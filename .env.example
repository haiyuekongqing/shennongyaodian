# ====================================
# TCM Agent API 环境变量配置
# ====================================

# 数据库配置
DATABASE_URL=

# Milvus 向量数据库配置
MILVUS_HOST=milvus
MILVUS_PORT=

# LLM 配置 (OpenAI 或兼容 API)
# ── 云端模式（示例） ──
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=GLM-4.7-Flash
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── 本地模式（Ollama + Qwen2.5-7B，推荐离线使用） ──
# 详见 docs/local-llm-deployment.md
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:7b
OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# Embedding 模型配置
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu  # cpu 或 cuda

# 知识库配置
KNOWLEDGE_BASE_DIR=/app/data/knowledge_base

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 安全配置
API_KEY=your_api_key_here  # 可选：API 认证密钥
